<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>zwisp</string>
    <key>CFBundleDisplayName</key>
    <string>zwisp</string>
    <key>CFBundleIdentifier</key>
    <string>com.local.zwisp</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0-beta</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>zwisp</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <!-- Menu-bar only app: no Dock icon. -->
    <key>LSUIElement</key>
    <true/>
    <!-- Required so macOS can prompt for microphone access. -->
    <key>NSMicrophoneUsageDescription</key>
    <string>zwisp records your voice while you hold your push-to-talk key and transcribes it on-device.</string>
    <!-- Allow the local HTTP call to the Ollama cleanup server on localhost. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
    <!-- "Add to zwisp Dictionary" in every app's right-click Services menu:
         select a name Whisper keeps mishearing and send its correct spelling
         to the personal dictionary. Handled by ServicesProvider.addToDictionary.
         macOS caches Service registrations; after changing this block, run
         /System/Library/CoreServices/pbs -flush and relaunch the app. -->
    <key>NSServices</key>
    <array>
        <dict>
            <key>NSMenuItem</key>
            <dict>
                <key>default</key>
                <string>Add to zwisp Dictionary</string>
            </dict>
            <key>NSMessage</key>
            <string>addToDictionary</string>
            <key>NSPortName</key>
            <string>zwisp</string>
            <key>NSSendTypes</key>
            <array>
                <string>NSStringPboardType</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
